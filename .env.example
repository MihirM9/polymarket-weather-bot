# ============================================================
# Polymarket Weather Trading Bot — Environment Configuration
# ============================================================
# Copy to .env and fill in real values before running.

# --- Polygon / Polymarket credentials ---
PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY_HERE
CHAIN_ID=137
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_FUNDER=              # leave blank unless using proxy wallet

# --- Telegram alerts ---
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- Trading parameters ---
# Bankroll in USDC
BANKROLL=500
# Max single-position size in USDC
MAX_POSITION_USD=10
# Daily loss cap (absolute USDC) — bot shuts down if breached
DAILY_LOSS_CAP=50
# Per-market max % of bankroll (0.02 = 2%)
PER_MARKET_MAX_PCT=0.03
# Fractional Kelly multiplier (0.1–0.25 recommended)
KELLY_FRACTION=0.15
# Minimum EV threshold to place a trade (0.03 = 3%)
MIN_EV_THRESHOLD=0.03
# Minimum edge (p_true - market_price) to act
MIN_EDGE=0.08
# Scan interval in seconds
SCAN_INTERVAL_SEC=120

# --- Ensemble blending (v3 Fix #2) ---
# Free tier: openweathermap.org/api → sign up → get API key
# Enables multi-source forecast blending (NWS + OWM)
# Leave blank to run NWS-only (still works, just single-source)
OPENWEATHER_API_KEY=

# --- Mode ---
# Set to "live" to place real orders; anything else = dry-run (default)
MODE=dry-run

# --- Cities (comma-separated, matched against market questions) ---
CITIES=New York,Chicago,Los Angeles,Miami,Houston,Dallas

# --- NWS Forecast Points (city_key:lat,lon — near major airport/station) ---
# These map to the NWS grid forecast endpoint
NWS_POINTS=New York:40.7789,-73.9692,Chicago:41.9742,-87.9073,Los Angeles:33.9425,-118.4081,Miami:25.7959,-80.2870,Houston:29.9844,-95.3414,Dallas:32.8998,-97.0403
